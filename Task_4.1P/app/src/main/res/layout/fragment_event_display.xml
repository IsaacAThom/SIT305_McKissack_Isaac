<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    tools:context=".EventDisplayFragment">

    <TextView
        android:id="@+id/event_list_header"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:background="#AD3D8C"
        android:text="@string/event_list_header"
        android:textColor="@color/white"
        android:fontFamily="casual"
        android:textSize="30sp"
        android:gravity="center"
        android:padding="10dp"
        />

    <!-- Displays the RecyclerView with all events inside -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/event_list_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/event_list_header"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/event_item"
        android:paddingBottom="70dp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>