<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="15dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#AB3082"
                android:textColor="#fff"
                android:text="Advert Type Label"
                android:padding="15dp"
                android:textSize="18sp"
                android:gravity="center_horizontal"
                />

            <TextView
                android:id="@+id/advert_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:text="Advert Title..." />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:text="Date"
                />
            <TextView
                android:id="@+id/advert_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date..." />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:text="Location"
                />
            <TextView
                android:id="@+id/advert_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:text="Location..." />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:text="Description"
                />
            <TextView
                android:id="@+id/advert_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description..." />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:text="Photo"
                />
            <ImageView
                android:id="@+id/advert_image"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop" />

            <Button
                android:id="@+id/remove_advert_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:layout_gravity="center_horizontal"
                android:gravity="bottom"
                android:padding="20dp"
                android:text="Remove" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>