<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".LostFoundListFragment"
    android:padding="15dp">

    <TextView
        android:id="@+id/lost_found_list_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center_horizontal"
        android:textSize="30sp"
        android:text="LOST &amp; FOUND LIST"/>

    <Spinner
        android:id="@+id/form_category_filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/form_filter_button"
        app:layout_constraintTop_toBottomOf="@id/lost_found_list_header"
        android:padding="15dp"
        android:layout_marginTop="10dp"
        />

    <Button
        android:id="@+id/form_filter_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@id/form_clear_filter_button"
        app:layout_constraintTop_toBottomOf="@id/lost_found_list_header"
        android:padding="15dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="15dp"
        android:text="Apply Filter"
        />

    <Button
        android:id="@+id/form_clear_filter_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lost_found_list_header"
        android:padding="15dp"
        android:layout_marginTop="10dp"
        android:text="Clear Filter"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lost_found_list_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/form_category_filter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp"
        tools:listitem="@layout/advert_item"/>

</androidx.constraintlayout.widget.ConstraintLayout>